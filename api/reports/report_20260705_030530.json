    "code": "df['Unit Cost'] = pd.to_numeric(df['Unit Cost'], errors='coerce')\ndf['Retail Price'] = pd.to_numeric(df['Retail Price'], errors='coerce')\ndf['Opening Stock'] = pd.to_numeric(df['Opening Stock'], errors='coerce')\ndf['Units Sold'] = pd.to_numeric(df['Units Sold'], errors='coerce')\ndf['Closing Stock'] = pd.to_numeric(df['Closing Stock'], errors='coerce')\ndf['Reorder Point'] = pd.to_numeric(df['Reorder Point'], errors='coerce')\n\ndf['Profit per Unit'] = df['Retail Price'] - df['Unit Cost']\n\ncategory_sales = df.groupby('Category')['Units Sold'].sum().sort_values(ascending=False)\nstock_status_counts = df['Stock Status'].value_counts()\n\nchart_labels = category_sales.index.tolist()\nchart_values = category_sales.values.tolist()\nchart_title = \"Total Units Sold by Category\"\n\navg_profit_per_unit = df['Profit per Unit'].mean()\n\ntop_categories_summary = \"\"\nif not category_sales.empty:\n    top_categories = category_sales.head(3)\n    top_categories_list = [f\"{cat} ({int(units)} units)\" for cat, units in top_categories.items()]\n    top_categories_summary = \"Top-performing categories by units sold are \" + \", \".join(top_categories_list) + \".\"\n\nstock_status_summary_parts = [f\"{status}: {count} products\" for status, count in stock_status_counts.items()]\nstock_status_summary_string = \"Current stock status distribution shows: \" + \", \".join(stock_status_summary_parts) + \".\"\n\nsummary_text = f\"The analysis provides an overall understanding of the dataset. \" \\\n               f\"The average profit per unit across all products is ${avg_profit_per_unit:.2f}. \" \\\n               f\"{top_categories_summary} \" \\\n               f\"{stock_status_summary_string}\"\n\nresult = {\n    \"chart_data\": {\n        \"labels\": chart_labels,\n        \"values\": chart_values,\n        \"title\": chart_title\n    },\n    \"summary\": summary_text\n}",
